# ── Connection ────────────────────────────────────────────────────────────────
# Instance origin. The /api prefix comes from the spec, so either form works.
PAPERCLIP_API_BASE_URL=http://localhost:3100

# Bearer token. Board API key (pcp_board_...) or an agent API key / JWT.
# Leave unset for a local_trusted instance with private exposure (implicit board access).
PAPERCLIP_API_KEY=

# Optional X-Paperclip-Run-Id, attached to every request (useful for agent runs).
# PAPERCLIP_RUN_ID=run_123

# ── OpenAPI source ──────────────────────────────────────────────────────────────
# auto (default): try live /api/openapi.json, fall back to the bundled snapshot.
# live: require the live document. bundled: always use the committed snapshot.
PAPERCLIP_OPENAPI_SOURCE=auto
# Override the live document URL (defaults to <base>/api/openapi.json):
# PAPERCLIP_OPENAPI_URL=http://localhost:3100/api/openapi.json

# ── Tool exposure ───────────────────────────────────────────────────────────────
# gateway (default): expose only meta-tools (search/inspect/call) — progressive discovery.
# direct: expose every (filtered) endpoint as its own tool, plus meta-tools.
# hybrid: expose only allowlisted endpoints (set PAPERCLIP_MCP_TAGS/INCLUDE), plus meta-tools.
PAPERCLIP_MCP_MODE=gateway

# Filters (apply in direct/hybrid mode):
# PAPERCLIP_MCP_TAGS=issues,agents,secrets
# PAPERCLIP_MCP_EXCLUDE_TAGS=instance,admin
# PAPERCLIP_MCP_INCLUDE=^(get|post)_companies   # regex on tool name or path
# PAPERCLIP_MCP_EXCLUDE=delete_

# Require confirm:true before destructive (DELETE) calls (default true).
PAPERCLIP_MCP_CONFIRM_DESTRUCTIVE=true
# Default number of results from paperclip_search_tools.
PAPERCLIP_MCP_SEARCH_LIMIT=10
# Truncate tool result text beyond this many chars (0 = unlimited).
PAPERCLIP_MCP_MAX_RESULT_CHARS=50000
# Expose the raw paperclip_request escape hatch (bypasses risk gating).
PAPERCLIP_MCP_RAW_REQUEST_TOOL=true

# ── Transport ───────────────────────────────────────────────────────────────────
# stdio (default) or http (Streamable HTTP).
PAPERCLIP_MCP_TRANSPORT=stdio
# PAPERCLIP_MCP_HTTP_HOST=127.0.0.1
# PAPERCLIP_MCP_HTTP_PORT=3333

# ── Misc ────────────────────────────────────────────────────────────────────────
# PAPERCLIP_HTTP_TIMEOUT_MS=30000
# PAPERCLIP_MCP_LOG_LEVEL=info   # debug|info|warn|error|silent
# PAPERCLIP_EXTRA_HEADERS={"X-Env":"staging"}
